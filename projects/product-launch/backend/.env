# ── Mock mode — set to false and fill real values when infra is ready ──────
USE_MOCKS=true

# PostgreSQL (only needed when USE_MOCKS=false)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/product_launch

# Redis (only needed when USE_MOCKS=false)
REDIS_URL=redis://localhost:6379

# App
PORT=4000
NODE_ENV=development

# CORS — React dev server
CORS_ORIGIN=http://localhost:5173

# Admin secret — passed as Authorization: Bearer <ADMIN_SECRET>
ADMIN_SECRET=change_me_in_production

# Email SMTP (only needed when USE_MOCKS=false)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=launch@yourproduct.com
